# Data — never commit (licenses + size); loaders re-fetch by pinned version + hash (PLAN §10)
/data/
# Results raw artifacts can be large; keep them out of git (the system of record is synced separately).
# Tables/figures are regenerated deterministically via `make`.
/results/raw/
/results/**/*.jsonl

# Python / uv
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
*.egg-info/

# Secrets
.env
*.key

# OS / editor
.DS_Store
.ipynb_checkpoints/
.specstory/

# Keep these tracked:
!.gitignore
!.python-version
